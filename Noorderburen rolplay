c FiveM Player HUD

local hudVisible = false

-- Show HUD when player spawns
Citizen.CreateThread(function()
    while true do
        Citizen.Wait(1000)
        if NetworkIsPlayerActive(PlayerId()) then
            hudVisible = true
            SendNUIMessage({type = 'showHUD'})
            break
        end
    end
end)

-- Update HUD every 500ms
Citizen.CreateThread(function()
    while true do
        Citizen.Wait(500)
        
        if IsPauseMenuActive() or IsEntityDead(PlayerPedId()) then
            if hudVisible then
                SendNUIMessage({type = 'hideHUD'})
                hudVisible = false
            end
        else
            if not hudVisible then
                SendNUIMessage({type = 'showHUD'})
                hudVisible = true
            end
            
            local player = PlayerPedId()
            
            -- Health
            local health = GetEntityHealth(player)
            local maxHealth = GetEntityMaxHealth(player)
            local healthValue = math.max(0, health - 100)
            local maxHealthValue = math.max(100, maxHealth - 100)
            
            -- Armor
            local armor = GetPedArmour(player)
            
            -- Hunger and Thirst (placeholders)
            local hunger = math.random(30, 100)
            local thirst = math.random(20, 100)
            
            SendNUIMessage({
                type = 'updateHUD',
                health = healthValue,
                maxHealth = maxHealthValue,
                armor = armor,
                hunger = hunger,
                thirst = thirst
            })
        end
    end
end)

